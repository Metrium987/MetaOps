# ══════════════════════════════════════════════════════════════════════════════
# MetaOps — Full configuration
# ══════════════════════════════════════════════════════════════════════════════
#
# Only the provider you actually use needs an API key.
# Everything else can stay empty.
#
# Model format: provider/model-name
#   Examples: openai/gpt-4o · anthropic/claude-opus-4-8 · groq/llama-3.3-70b-versatile
#             deepseek/deepseek-chat · xai/grok-3 · mistral/mistral-large-latest
#             gemini/gemini-2.5-pro · ollama/llama3 · lmstudio/local-model
# ══════════════════════════════════════════════════════════════════════════════


# ── Telegram (optional — required for Telegram gateway) ───────────────────────
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user IDs allowed to use the bot.
# Leave empty during local testing; set before sharing the bot with anyone —
# a Telegram bot is reachable by anyone who knows its username, not just
# people on your local network.
METAOPS_TELEGRAM_ALLOWED_USERS=

# ── MCP Server (optional — fallback when mcp_servers.json is absent) ──────────
MCP_SERVER_URL=http://localhost:8000/sse


# ══════════════════════════════════════════════════════════════════════════════
# AGGREGATORS  (hundreds of models via a single key)
# ══════════════════════════════════════════════════════════════════════════════

# NousResearch — Hermes models + community models
NOUSRESEARCH_API_KEY=
NOUSRESEARCH_BASE_URL=https://inference-api.nousresearch.com/v1

# OpenRouter — 300+ models (recommended starting point)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Novita AI — hosted open-source models
NOVITA_API_KEY=
NOVITA_BASE_URL=https://api.novita.ai/v1

# Kilo Code — dev-focused aggregator
KILOCODE_API_KEY=
KILOCODE_BASE_URL=https://api.kilo.ai/api/gateway

# OpenCode Zen — open-source aggregator
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1


# ══════════════════════════════════════════════════════════════════════════════
# STORAGE — database paths
# ══════════════════════════════════════════════════════════════════════════════

# SQLite — conversation history (sessions + events)
METAOPS_SESSIONS_DB=./data/metaops_sessions.db

# SQLite — learned skills / procedures
METAOPS_SKILLS_DB=./data/metaops_skills.db

# ChromaDB — vector memory (episodic, semantic, procedural, persona)
METAOPS_VECTOR_DB=./data/metaops_vector_db

# FileArtifactService — persistent artifacts (generated files, exports, reports)
METAOPS_ARTIFACTS_DIR=./data/artifacts


# ══════════════════════════════════════════════════════════════════════════════
# WEB SEARCH
# ══════════════════════════════════════════════════════════════════════════════

# Tavily — web search (get your key at app.tavily.com)
TAVILY_API_KEY=


# ══════════════════════════════════════════════════════════════════════════════
# MAIN CLOUD PROVIDERS
# ══════════════════════════════════════════════════════════════════════════════

# OpenAI — GPT-4o, o3, etc.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic — Claude 4 / 3.5 / 3
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini — Gemini 2.5 Pro/Flash
GOOGLE_API_KEY=
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# xAI — Grok-3, Grok-2
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# DeepSeek — deepseek-chat, deepseek-r1
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Mistral AI — mistral-large, codestral, voxtral
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Groq — ultra-fast inference (llama, qwen, etc.)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Perplexity — models with built-in web search
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai

# Cohere — Command R+
COHERE_API_KEY=
COHERE_BASE_URL=https://api.cohere.ai/v1

# Together AI — open-source models
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.ai/v1

# Fireworks AI — fast open-source model inference
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# NVIDIA NIM — NVIDIA-accelerated models
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Hugging Face Inference Router
HF_TOKEN=
HF_BASE_URL=https://router.huggingface.co/v1

# GitHub Copilot (requires GH token with Copilot access)
COPILOT_GITHUB_TOKEN=
COPILOT_API_BASE_URL=https://api.githubcopilot.com

# Arcee AI — enterprise SLMs
ARCEEAI_API_KEY=
ARCEE_BASE_URL=https://api.arcee.ai/api/v1

# GMI Cloud
GMI_API_KEY=
GMI_BASE_URL=https://api.gmi-serving.com/v1

# Azure AI Foundry (user-provided endpoint)
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_BASE_URL=


# ══════════════════════════════════════════════════════════════════════════════
# ASIAN PROVIDERS
# ══════════════════════════════════════════════════════════════════════════════

# Alibaba Cloud / Qwen (DashScope international)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Kimi / Moonshot (kimi-k2, moonshot-v1-*)
KIMI_API_KEY=
KIMI_CODING_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1

# MiniMax (MoE-A1, abab6.5)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/anthropic

# StepFun (Step-2, Step-1V)
STEPFUN_API_KEY=
STEPFUN_BASE_URL=https://api.stepfun.ai/step_plan/v1

# Z.AI / GLM (GLM-4, CogVideo)
GLM_API_KEY=
ZAI_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/paas/v4

# Xiaomi MiMo
XIAOMI_API_KEY=
XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1

# Tencent TokenHub
TOKENHUB_API_KEY=
TOKENHUB_BASE_URL=https://tokenhub.tencentmaas.com/v1


# ══════════════════════════════════════════════════════════════════════════════
# LOCAL / SELF-HOSTED
# ══════════════════════════════════════════════════════════════════════════════

# Ollama (local models: ollama/llama3, ollama/qwen2.5-coder, etc.)
OLLAMA_BASE_URL=http://localhost:11434/v1

# LM Studio (local OpenAI-compatible interface)
LM_API_KEY=
LM_BASE_URL=http://127.0.0.1:1234/v1


# ══════════════════════════════════════════════════════════════════════════════
# PER-AGENT MODELS
# Each agent can use a different provider and model.
# ══════════════════════════════════════════════════════════════════════════════

# Main coordinator agent — powerful model recommended
METAOPS_COORDINATOR_MODEL=openai/gpt-4o
METAOPS_COORDINATOR_PROVIDER=openrouter

# Workstream agent (long pipelines) — fast/cheaper model
METAOPS_WORKSTREAM_MODEL=openai/gpt-4o-mini
METAOPS_WORKSTREAM_PROVIDER=openrouter

# Background audit agent — lightweight is enough
METAOPS_AUDITOR_MODEL=openai/gpt-4o-mini
METAOPS_AUDITOR_PROVIDER=openrouter


# ══════════════════════════════════════════════════════════════════════════════
# EMBEDDINGS (ChromaDB RAG)
# ══════════════════════════════════════════════════════════════════════════════

# "local" = ONNX bundled in ChromaDB (no key required, slow on first start ~300ms)
# "api"   = OpenAI-compatible API (OpenRouter, OpenAI, etc.)
METAOPS_EMBEDDING_PROVIDER=local

# Only needed when METAOPS_EMBEDDING_PROVIDER=api:
METAOPS_EMBEDDING_MODEL=openai/text-embedding-3-small
METAOPS_EMBEDDING_API_KEY=          # leave empty to reuse OPENROUTER_API_KEY
METAOPS_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1


# ══════════════════════════════════════════════════════════════════════════════
# APPLICATION CONFIGURATION & ROLES
# ══════════════════════════════════════════════════════════════════════════════

# Target platform for cron deliveries: "cli" or "telegram:<chat_id>"
METAOPS_CRON_DELIVERY_TARGET=cli

# Default role permissions ("admin" for full shell, "user" for restricted shell, "guest" for no shell)
METAOPS_DEFAULT_CLI_ROLE=admin
METAOPS_DEFAULT_CRON_ROLE=admin
METAOPS_DEFAULT_TELEGRAM_ROLE=admin

